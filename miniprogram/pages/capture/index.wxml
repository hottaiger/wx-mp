<view class="page">
  <!-- 顶部 -->
  <view class="head">
    <view class="head__back" hover-class="press" bindtap="onBack">‹</view>
    <view class="head__title">记一笔</view>
    <view class="head__spacer"></view>
  </view>

  <!-- Segmented Tab -->
  <view class="seg">
    <view
      wx:for="{{tabs}}"
      wx:key="key"
      class="seg__item {{activeTab === item.key ? 'seg__item--on' : ''}}"
      data-key="{{item.key}}"
      hover-class="press"
      bindtap="onTabTap"
    >{{item.label}}</view>
  </view>

  <!-- 表单 -->
  <view class="form">
    <!-- 事件 -->
    <block wx:if="{{activeTab === 'event'}}">
      <view class="group">
        <view class="group__title">这件事</view>
        <input class="form-input form-input--title" placeholder="给它一个名字" placeholder-class="form-input__ph" data-field="title" value="{{form.title}}" bindinput="onFieldInput" />
        <view class="chip-row">
          <view
            wx:for="{{eventTypes}}"
            wx:key="value"
            class="chip {{form.type === item.value ? 'chip--on' : ''}}"
            data-value="{{item.value}}"
            hover-class="press"
            bindtap="onEventTypeSelect"
          >{{item.label}}</view>
        </view>
      </view>

      <view class="group">
        <view class="group__title">时间</view>
        <view class="form-row form-row--split">
          <view class="form-row__col">
            <text class="form-row__label">日期</text>
            <picker mode="date" value="{{form.startDate}}" bindchange="onStartDateChange">
              <view class="picker {{form.startDate ? '' : 'picker--ph'}}">{{form.startDate || '选择'}}</view>
            </picker>
          </view>
          <view class="form-row__col">
            <text class="form-row__label">时间</text>
            <picker mode="time" value="{{form.startTime}}" bindchange="onStartTimeChange">
              <view class="picker {{form.startTime ? '' : 'picker--ph'}}">{{form.startTime || '选择'}}</view>
            </picker>
          </view>
        </view>
        <view class="form-row" wx:if="{{form.type === 'meeting'}}">
          <text class="form-row__label">时长</text>
          <input class="form-input form-input--inline" type="number" data-field="durationMin" value="{{form.durationMin}}" bindinput="onFieldInput" placeholder="分钟" />
        </view>
      </view>

      <view class="group">
        <view class="group__title">补充</view>
        <textarea class="form-input form-input--multi" placeholder="详细描述…" placeholder-class="form-input__ph" data-field="description" value="{{form.description}}" bindinput="onFieldInput" />
      </view>
    </block>

    <!-- 人物 -->
    <block wx:if="{{activeTab === 'person'}}">
      <view class="group">
        <view class="group__title">他/她</view>
        <input class="form-input form-input--title" placeholder="姓名" placeholder-class="form-input__ph" data-field="name" value="{{form.name}}" bindinput="onFieldInput" />
      </view>
      <view class="group">
        <view class="group__title">特点</view>
        <input class="form-input" placeholder="逗号分隔，例：内敛, 爱喝咖啡" placeholder-class="form-input__ph" data-field="traitsStr" value="{{form.traitsStr}}" bindinput="onFieldInput" />
      </view>
      <view class="group">
        <view class="group__title">标签 & 备注</view>
        <input class="form-input" placeholder="标签，逗号分隔" placeholder-class="form-input__ph" data-field="tagsStr" value="{{form.tagsStr}}" bindinput="onFieldInput" />
        <textarea class="form-input form-input--multi" placeholder="备注…" placeholder-class="form-input__ph" data-field="note" value="{{form.note}}" bindinput="onFieldInput" />
      </view>
    </block>

    <!-- 物品 -->
    <block wx:if="{{activeTab === 'item'}}">
      <view class="group">
        <view class="group__title">这个物品</view>
        <input class="form-input form-input--title" placeholder="物品名" placeholder-class="form-input__ph" data-field="name" value="{{form.name}}" bindinput="onFieldInput" />
      </view>
      <view class="group">
        <view class="group__title">主图</view>
        <view class="image-upload" wx:if="{{!form.coverImage}}" hover-class="press" bindtap="onChooseItemImage">
          <text class="image-upload__plus">+</text>
          <text class="image-upload__label">上传图片</text>
        </view>
        <view class="image-preview" wx:if="{{form.coverImage}}">
          <image class="image-preview__img" src="{{form.coverImage.tempFilePath || form.coverImage.fileID}}" mode="aspectFill" />
          <view class="image-preview__actions">
            <view class="image-action" hover-class="press" bindtap="onChooseItemImage">替换</view>
            <view class="image-action image-action--danger" hover-class="press" bindtap="onRemoveItemImage">删除</view>
          </view>
        </view>
      </view>
      <view class="group">
        <view class="group__title">购入</view>
        <picker mode="date" value="{{form.boughtDate}}" bindchange="onBoughtDateChange">
          <view class="picker {{form.boughtDate ? '' : 'picker--ph'}}">{{form.boughtDate || '选择购入日期'}}</view>
        </picker>
      </view>
      <view class="group">
        <view class="group__title">属性</view>
        <view wx:if="{{form.attrs.length}}" class="attr-list">
          <view wx:for="{{form.attrs}}" wx:key="key" wx:for-index="idx" class="attr-row">
            <text class="attr-row__k">{{item.key}}</text>
            <text class="attr-row__v">{{item.value}}</text>
            <view class="attr-row__del" data-index="{{idx}}" hover-class="press" bindtap="onRemoveAttr">×</view>
          </view>
        </view>
        <view class="attr-input">
          <input class="form-input form-input--attr" placeholder="属性名" placeholder-class="form-input__ph" data-field="newAttrKey" value="{{form.newAttrKey}}" bindinput="onAttrKeyInput" />
          <input class="form-input form-input--attr" placeholder="值" placeholder-class="form-input__ph" data-field="newAttrValue" value="{{form.newAttrValue}}" bindinput="onAttrValueInput" />
          <view class="attr-add" hover-class="press" bindtap="onAddAttr">+</view>
        </view>
      </view>
      <view class="group">
        <view class="group__title">标签 & 备注</view>
        <input class="form-input" placeholder="标签，逗号分隔" placeholder-class="form-input__ph" data-field="tagsStr" value="{{form.tagsStr}}" bindinput="onFieldInput" />
        <textarea class="form-input form-input--multi" placeholder="备注…" placeholder-class="form-input__ph" data-field="note" value="{{form.note}}" bindinput="onFieldInput" />
      </view>
    </block>

    <!-- 提醒 -->
    <view class="group">
      <view class="group__head">
        <view class="group__title">提醒我</view>
        <switch checked="{{reminderEnabled}}" bindchange="onReminderToggle" color="#2F4A3A" />
      </view>
      <block wx:if="{{reminderEnabled}}">
        <view class="chip-row">
          <view
            wx:for="{{reminderPresets}}"
            wx:key="*this"
            class="chip {{reminderPreset === item ? 'chip--on' : ''}}"
            data-value="{{item}}"
            hover-class="press"
            bindtap="onReminderPresetSelect"
          >{{item}}</view>
        </view>
        <input class="form-input" placeholder="或自定义：明晚 8 点 / 06-10 09:00" placeholder-class="form-input__ph" value="{{reminderCustom}}" bindinput="onReminderCustomInput" />
      </block>
    </view>
  </view>

  <!-- 浮动提交 -->
  <view class="dock">
    <checkbox-group class="privacy-consent" catchtap="noop" bindchange="onPrivacyConsentChange">
      <label class="privacy-consent__label">
        <checkbox value="agreed" checked="{{privacyAgreed}}" color="#2F4A3A" />
        <text>我已阅读并同意</text>
      </label>
      <text class="privacy-consent__link" data-type="service" catchtap="onOpenAgreement">《用户服务协议》</text>
      <text>和</text>
      <text class="privacy-consent__link" data-type="privacy" catchtap="onOpenAgreement">《隐私政策》</text>
    </checkbox-group>
    <view class="dock__btn {{submitting ? 'dock__btn--disabled' : ''}}" hover-class="{{submitting ? '' : 'press'}}" bindtap="onSubmit">保存</view>
  </view>

  <view class="privacy-dialog" wx:if="{{privacyDialogVisible}}" catchtouchmove="noop">
    <view class="privacy-dialog__mask" bindtap="onClosePrivacyDialog"></view>
    <view class="privacy-dialog__panel">
      <view class="privacy-dialog__head">
        <text class="privacy-dialog__title">{{privacyDialogTitle}}</text>
        <view class="privacy-dialog__close" bindtap="onClosePrivacyDialog">×</view>
      </view>
      <scroll-view class="privacy-dialog__body" scroll-y>
        <view class="privacy-dialog__section" wx:for="{{privacyDialogSections}}" wx:key="title">
          <view class="privacy-dialog__section-title">{{item.title}}</view>
          <view class="privacy-dialog__paragraph" wx:for="{{item.paragraphs}}" wx:key="*this" wx:for-item="paragraph">{{paragraph}}</view>
        </view>
      </scroll-view>
    </view>
  </view>
</view>
