.container { padding: 24rpx; padding-bottom: 120rpx; background: #f6f6f6; min-height: 100vh; }
.tabs { display: flex; background: #fff; border-radius: 12rpx; padding: 6rpx; margin-bottom: 24rpx; }
.tab { flex: 1; text-align: center; padding: 16rpx 0; font-size: 30rpx; color: #666; border-radius: 10rpx; }
.tab--active { background: #2c7be5; color: #fff; }
.field { background: #fff; padding: 20rpx 24rpx; margin-bottom: 16rpx; border-radius: 12rpx; }
.field-row { display: flex; gap: 16rpx; }
.field--half { flex: 1; }
.field__label { font-size: 24rpx; color: #999; margin-bottom: 10rpx; }
.field__input { width: 100%; font-size: 30rpx; padding: 4rpx 0; }
.field__input--inline { display: inline-block; width: 30%; }
.picker { font-size: 30rpx; color: #1a1a1a; padding: 4rpx 0; }
.chip-row { display: flex; flex-wrap: wrap; gap: 12rpx; }
.chip { background: #f0f0f0; color: #555; padding: 10rpx 20rpx; border-radius: 30rpx; font-size: 26rpx; }
.chip--active { background: #2c7be5; color: #fff; }
.attr-list { margin-bottom: 12rpx; }
.attr-item { display: flex; align-items: center; padding: 12rpx 0; border-bottom: 1rpx solid #f0f0f0; }
.attr-item__k { flex: 0 0 200rpx; font-size: 28rpx; color: #555; }
.attr-item__v { flex: 1; font-size: 28rpx; color: #1a1a1a; }
.attr-item__del { color: #e54c4c; padding: 0 16rpx; font-size: 36rpx; }
.attr-input { display: flex; gap: 8rpx; align-items: center; }
.btn-mini { background: #2c7be5; color: #fff; padding: 14rpx 24rpx; border-radius: 8rpx; font-size: 26rpx; }
.reminder { background: #fff; padding: 20rpx 24rpx; border-radius: 12rpx; margin-bottom: 24rpx; }
.reminder__head { display: flex; align-items: center; gap: 16rpx; margin-bottom: 12rpx; }
.reminder__label { font-size: 30rpx; color: #1a1a1a; }
.submit-btn { background: #2c7be5; color: #fff; text-align: center; padding: 24rpx 0; border-radius: 12rpx; font-size: 32rpx; margin-top: 16rpx; }
.submit-btn--disabled { background: #aaa; }
