.container { padding: 24rpx; background: #f6f6f6; min-height: 100vh; padding-bottom: 120rpx; }
.section { background: #fff; border-radius: 16rpx; padding: 20rpx 24rpx; margin-bottom: 16rpx; }
.section__title { font-size: 26rpx; color: #999; margin-bottom: 16rpx; }
.from { font-size: 30rpx; color: #1a1a1a; font-weight: 500; }
.chip-row { display: flex; flex-wrap: wrap; gap: 12rpx; }
.chip { background: #f0f0f0; color: #555; padding: 10rpx 20rpx; border-radius: 30rpx; font-size: 26rpx; }
.chip--active { background: #2c7be5; color: #fff; }
.chip--disabled { opacity: 0.4; }
.entity-card { padding: 20rpx; border: 2rpx solid transparent; border-radius: 12rpx; margin-bottom: 12rpx; background: #f9f9f9; }
.entity-card--active { border-color: #2c7be5; background: #eef3fb; }
.entity-card__title { font-size: 30rpx; color: #1a1a1a; }
.empty { text-align: center; color: #999; padding: 40rpx 0; font-size: 28rpx; }
.submit-btn { background: #2c7be5; color: #fff; text-align: center; padding: 24rpx 0; border-radius: 12rpx; font-size: 32rpx; }
