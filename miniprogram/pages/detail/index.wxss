.container { padding: 24rpx; background: #f6f6f6; min-height: 100vh; }
.header { display: flex; justify-content: space-between; align-items: center; padding: 16rpx 0; }
.title { font-size: 40rpx; font-weight: 600; }
.actions { display: flex; }
.action { color: #2c7be5; padding: 8rpx 16rpx; font-size: 28rpx; }
.action--danger { color: #e54c4c; }
.tabs { display: flex; background: #fff; border-radius: 12rpx; padding: 6rpx; margin-bottom: 16rpx; }
.tab { flex: 1; text-align: center; padding: 14rpx 0; font-size: 28rpx; color: #666; border-radius: 10rpx; }
.tab--active { background: #2c7be5; color: #fff; }
.section { background: #fff; border-radius: 16rpx; padding: 16rpx 24rpx; }
.field { padding: 20rpx 0; border-bottom: 1rpx solid #f0f0f0; }
.field:last-child { border-bottom: none; }
.field__label { font-size: 24rpx; color: #999; margin-bottom: 8rpx; }
.field__value { font-size: 30rpx; color: #1a1a1a; }
.field__input { width: 100%; font-size: 30rpx; padding: 8rpx 0; box-sizing: border-box; }
.tag { display: inline-block; background: #eef3fb; color: #2c7be5; font-size: 24rpx; padding: 6rpx 16rpx; border-radius: 20rpx; margin-right: 12rpx; margin-top: 6rpx; }
.btn-row { display: flex; gap: 16rpx; margin-top: 32rpx; }
.btn { flex: 1; text-align: center; padding: 20rpx 0; border-radius: 12rpx; font-size: 30rpx; }
.btn--ghost { background: #f0f0f0; color: #666; }
.btn--primary { background: #2c7be5; color: #fff; }
.add-relation { background: #eef3fb; color: #2c7be5; padding: 20rpx; text-align: center; border-radius: 12rpx; margin-bottom: 16rpx; }
.rel-card { background: #f9f9f9; padding: 20rpx; border-radius: 12rpx; margin-bottom: 12rpx; display: flex; justify-content: space-between; align-items: center; }
.rel-card__rel { font-size: 26rpx; color: #555; }
.rel-card__arrow { color: #2c7be5; font-size: 32rpx; }
.empty { text-align: center; padding: 60rpx 0; color: #999; }
.empty__text { font-size: 28rpx; }
.loading { text-align: center; padding: 200rpx 0; color: #999; }
