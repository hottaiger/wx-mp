.page { padding: 0 var(--s-3) var(--s-5); min-height: 100vh; }

.hero { padding: var(--s-5) 0 var(--s-4); }
.hero__crumb { font-size: var(--t-micro); color: var(--ink-3); letter-spacing: 2rpx; text-transform: uppercase; }
.hero__big { display: flex; align-items: baseline; margin: 16rpx 0 8rpx; }
.hero__num { font-size: 144rpx; font-weight: 600; color: var(--ink-1); line-height: 1; letter-spacing: -4rpx; }
.hero__unit { font-size: 36rpx; color: var(--ink-2); margin-left: 16rpx; font-weight: 400; }
.hero__caption { font-size: var(--t-meta); color: var(--ink-3); }

.card { background: var(--bg-elevated); border: 1rpx solid var(--line); border-radius: var(--r-md); padding: var(--s-3); margin-bottom: var(--s-3); }
.card__title { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: var(--s-3); }
.card__title text:first-child { font-size: 30rpx; font-weight: 500; color: var(--ink-1); }
.card__sub { font-size: var(--t-micro); color: var(--ink-3); }

.bars { display: flex; align-items: flex-end; justify-content: space-around; height: 280rpx; padding: var(--s-2) 0; }
.bar { display: flex; flex-direction: column; align-items: center; flex: 1; }
.bar__count { font-size: var(--t-micro); color: var(--ink-2); height: 30rpx; }
.bar__fill { width: 56rpx; background: var(--brand); border-radius: 12rpx 12rpx 4rpx 4rpx; margin-top: 4rpx; min-height: 4rpx; transition: height 0.3s; }
.bar__day { font-size: var(--t-micro); color: var(--ink-3); margin-top: 12rpx; }

.rank { display: flex; align-items: center; padding: 20rpx 0; border-top: 1rpx solid var(--line); }
.rank:first-of-type { border-top: none; }
.rank__no { width: 56rpx; height: 56rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 28rpx; font-weight: 500; background: var(--bg-subtle); color: var(--ink-2); margin-right: var(--s-2); flex-shrink: 0; }
.rank__no--1 { background: var(--brand); color: #fff; }
.rank__no--2 { background: var(--brand-soft); color: var(--brand); }
.rank__no--3 { background: var(--accent-soft); color: var(--accent); }
.rank__main { flex: 1; min-width: 0; }
.rank__name { font-size: 30rpx; color: var(--ink-1); font-weight: 500; }
.rank__traits { font-size: var(--t-meta); color: var(--ink-3); margin-top: 4rpx; }
.rank__arrow { color: var(--ink-3); font-size: 40rpx; line-height: 1; }

.empty { text-align: center; padding: 30rpx 0; }
.empty__sub { font-size: var(--t-meta); color: var(--ink-3); }
.press { opacity: 0.5; }
