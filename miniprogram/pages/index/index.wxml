<view class="container">
  <view class="header">
    <view class="title">微录</view>
    <view class="weekly-btn" bindtap="gotoWeekly">周复盘</view>
  </view>

  <view class="tabs">
    <view
      wx:for="{{tabs}}"
      wx:key="key"
      class="tab {{activeTab === item.key ? 'tab--active' : ''}}"
      data-key="{{item.key}}"
      bindtap="onTabTap"
    >{{item.label}}</view>
  </view>

  <view class="search">
    <input
      class="search__input"
      placeholder="搜索..."
      value="{{keyword}}"
      bindinput="onSearchInput"
      confirm-type="search"
    />
  </view>

  <view class="list" wx:if="{{list.length}}">
    <view
      wx:for="{{list}}"
      wx:key="_id"
      class="entity-card"
      data-id="{{item._id}}"
      data-type="{{activeTab}}"
      bindtap="onItemTap"
    >
      <view class="entity-card__title">{{item.name || item.title}}</view>
      <view class="entity-card__meta" wx:if="{{item.type}}">{{item.type}}</view>
      <view class="entity-card__meta" wx:if="{{item.startAt}}">{{item.startAtText}}</view>
      <view class="entity-card__meta" wx:if="{{item.boughtAt}}">购于 {{item.boughtAtText}}</view>
      <view class="entity-card__tags" wx:if="{{item.tags && item.tags.length}}">
        <text wx:for="{{item.tags}}" wx:for-item="t" wx:key="*this" class="tag">{{t}}</text>
      </view>
    </view>
  </view>

  <view class="empty" wx:elif="{{!loading}}">
    <view class="empty__icon">∅</view>
    <view class="empty__text">还没有{{tabs[0].label}}记录</view>
    <view class="empty__hint">点右下角 + 录入</view>
  </view>

  <view class="fab" bindtap="onFabTap">+</view>
</view>
