<view class="page">
  <!-- 顶部 hero：标题 + 副标题 + 统计 -->
  <view class="hero">
    <view class="hero__top">
      <view class="hero__brand">微录</view>
      <view class="hero__weekly" hover-class="press" bindtap="gotoWeekly">
        <text class="hero__weekly-ic">◐</text>
        <text>周复盘</text>
      </view>
    </view>
    <view class="hero__title">{{heroTitle}}</view>
    <view class="hero__sub">{{heroSub}}</view>
  </view>

  <!-- Segmented Tab -->
  <view class="seg">
    <view
      wx:for="{{tabs}}"
      wx:key="key"
      class="seg__item {{activeTab === item.key ? 'seg__item--on' : ''}}"
      data-key="{{item.key}}"
      hover-class="press"
      bindtap="onTabTap"
    >
      <text>{{item.label}}</text>
      <text class="seg__count" wx:if="{{counts[item.key] != null}}">{{counts[item.key]}}</text>
    </view>
  </view>

  <!-- 搜索条 -->
  <view class="search">
    <view class="search__ic">⌕</view>
    <input
      class="search__input"
      placeholder="搜索{{tabs[tabIndex].label}}…"
      placeholder-class="search__ph"
      value="{{keyword}}"
      bindinput="onSearchInput"
      confirm-type="search"
    />
  </view>

  <!-- 列表 -->
  <view class="list">
    <view
      wx:for="{{list}}"
      wx:key="_id"
      class="card {{activeTab === 'item' ? 'card--media' : ''}}"
      hover-class="card--press"
      data-id="{{item._id}}"
      data-type="{{activeTab}}"
      bindtap="onItemTap"
    >
      <image wx:if="{{activeTab === 'item' && item.coverImage && item.coverImage.fileID}}" class="card__thumb" src="{{item.coverImage.fileID}}" mode="aspectFill" />
      <view class="card__body">
        <view class="card__line">
          <view class="card__title">{{item.name || item.title}}</view>
          <view wx:if="{{activeTab === 'event' && item.type}}" class="chip chip--{{item.type}}">{{typeLabel[item.type]}}</view>
        </view>
        <view class="card__meta" wx:if="{{activeTab === 'event' && item.startAtText}}">
          <text class="card__meta-ic">◷</text>
          <text>{{item.startAtText}}</text>
          <text wx:if="{{item.durationMin}}"> · {{item.durationMin}} 分钟</text>
        </view>
        <view class="card__meta" wx:if="{{activeTab === 'item' && item.boughtAtText}}">
          <text class="card__meta-ic">◈</text>
          <text>添加 {{item.boughtAtText}}</text>
        </view>
        <view class="card__meta" wx:if="{{activeTab === 'person' && item.traits && item.traits.length}}">
          <text wx:for="{{item.traits}}" wx:for-item="t" wx:key="*this" class="trait">{{t}}</text>
        </view>
        <view class="card__tags" wx:if="{{item.tags && item.tags.length}}">
          <text wx:for="{{item.tags}}" wx:for-item="t" wx:key="*this" class="tag">#{{t}}</text>
        </view>
      </view>
    </view>

    <!-- 空态 -->
    <view class="empty" wx:if="{{!loading && !list.length}}">
      <view class="empty__art">⌀</view>
      <view class="empty__title">还没有{{tabs[tabIndex].label}}</view>
      <view class="empty__sub">点右下角 · 记下第一笔</view>
    </view>
  </view>

  <!-- 悬浮 FAB -->
  <view class="fab" hover-class="fab--press" bindtap="onFabTap">
    <text class="fab__plus">+</text>
  </view>
</view>
