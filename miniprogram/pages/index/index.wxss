.container {
  padding: 0 24rpx 120rpx;
  background-color: #f6f6f6;
  min-height: 100vh;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 8rpx 16rpx;
}
.title {
  font-size: 48rpx;
  font-weight: 600;
  color: #1a1a1a;
}
.weekly-btn {
  font-size: 26rpx;
  color: #2c7be5;
  padding: 8rpx 20rpx;
  border: 1rpx solid #2c7be5;
  border-radius: 30rpx;
}

.tabs {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  margin: 16rpx 0;
  padding: 8rpx;
}
.tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 30rpx;
  color: #666;
  border-radius: 12rpx;
}
.tab--active {
  background: #2c7be5;
  color: #fff;
}

.search {
  margin-bottom: 16rpx;
}
.search__input {
  background: #fff;
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
}

.entity-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}
.entity-card__title {
  font-size: 32rpx;
  font-weight: 500;
  color: #1a1a1a;
  margin-bottom: 8rpx;
}
.entity-card__meta {
  font-size: 24rpx;
  color: #888;
  margin-top: 4rpx;
}
.entity-card__tags {
  margin-top: 12rpx;
}
.tag {
  display: inline-block;
  background: #eef3fb;
  color: #2c7be5;
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  margin-right: 12rpx;
}

.empty {
  text-align: center;
  padding: 120rpx 0;
  color: #999;
}
.empty__icon {
  font-size: 80rpx;
  color: #ddd;
}
.empty__text {
  font-size: 30rpx;
  margin-top: 16rpx;
}
.empty__hint {
  font-size: 24rpx;
  margin-top: 8rpx;
  color: #bbb;
}

.fab {
  position: fixed;
  right: 48rpx;
  bottom: 64rpx;
  width: 110rpx;
  height: 110rpx;
  background: #2c7be5;
  color: #fff;
  border-radius: 50%;
  text-align: center;
  line-height: 110rpx;
  font-size: 60rpx;
  font-weight: 300;
  box-shadow: 0 8rpx 24rpx rgba(44, 123, 229, 0.35);
}
